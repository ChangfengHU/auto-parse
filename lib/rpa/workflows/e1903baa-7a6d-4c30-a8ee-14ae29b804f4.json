{
  "id": "e1903baa-7a6d-4c30-a8ee-14ae29b804f4",
  "name": "gemini流程管理-续话下载测试",
  "description": null,
  "nodes": [
    {
      "type": "navigate",
      "label": "导航",
      "params": {
        "url": "https://gemini.google.com/app/f9b5ff289b4240ca",
        "adsApiUrl": "http://127.0.0.1:50325",
        "waitUntil": "domcontentloaded",
        "useAdsPower": true,
        "adsProfileId": "{{browserInstanceId}}",
        "adsProxyServer": "",
        "adsManualCdpUrl": "{{browserWsUrl}}"
      },
      "waitAfter": {
        "action": "appeared",
        "enabled": true,
        "timeout": 60000,
        "selector": "rich-textarea .ql-editor[contenteditable=\"true\"], div.ql-editor[contenteditable=\"true\"]"
      }
    },
    {
      "type": "click",
      "label": "点击",
      "params": {
        "text": "Create image",
        "selector": ""
      },
      "waitAfter": {
        "enabled": false,
        "timeout": 100000,
        "selector": "img[src^=\"blob:\"]",
        "delaySeconds": 3
      },
      "continueOnError": true
    },
    {
      "type": "text_input",
      "label": "文本输入",
      "params": {
        "value": "{{noteUrl}}",
        "selector": "rich-textarea .ql-editor[contenteditable=\"true\"], div.ql-editor[contenteditable=\"true\"]"
      }
    },
    {
      "type": "click",
      "label": "点击",
      "params": {
        "text": "",
        "selector": "button[aria-label=\"Send message\"], button[aria-label=\"发送消息\"]"
      },
      "waitAfter": {
        "enabled": false,
        "timeout": 240000,
        "selector": "[aria-label=\"Copy image\"], [aria-label=\"复制图片\"]",
        "delaySeconds": 3
      }
    },
    {
      "type": "extract_image_download",
      "label": "⬇️ 下载事件提取（续话增强版）",
      "params": {
        "ossPath": "gemini-images/{{timestamp}}.png",
        "outputVar": "imageUrl",
        "maxRetries": 5,
        "waitForNew": true,
        "buttonIndex": -1,
        "uploadToOSS": true,
        "buttonTimeout": 60000,
        "waitAfterClick": 500,
        "downloadTimeout": 35000,
        "allowDomFallback": false,
        "menuItemSelector": "[role=\"menuitem\"]:has-text(\"Download\"), [role=\"menuitem\"]:has-text(\"下载\"), button:has-text(\"Download\"), button:has-text(\"下载\")",
        "minFileSizeBytes": 524288,
        "waitForNewTimeout": 120000,
        "menuTriggerSelector": "button[aria-label*=\"More options\"], button[aria-label*=\"更多\"]",
        "allowClipboardFallback": false,
        "downloadButtonSelector": "[aria-label=\"Download image\"], [aria-label*=\"Download\"], [aria-label*=\"下载\"], button:has-text(\"Download\"), button:has-text(\"下载\")",
        "serializeClipboardAccess": true
      },
      "waitAfter": {
        "enabled": true
      },
      "continueOnError": false
    }
  ],
  "vars": [
    "browserInstanceId",
    "browserWsUrl",
    "noteUrl"
  ]
}