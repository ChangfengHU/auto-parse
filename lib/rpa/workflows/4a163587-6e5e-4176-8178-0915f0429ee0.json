{
  "id": "4a163587-6e5e-4176-8178-0915f0429ee0",
  "name": "gemini流程管理-ads-下载提取版",
  "description": "基于非Ads基线流程，仅首节点切换Ads并支持浏览器实例参数\n\n支持可选参考图：sourceImageUrl（单张）/ sourceImageUrls（多张，JSON 数组或逗号分隔）。\n\n文本输入仅由后续「点击发送」提交，避免与 autoEnter 双重发送；DOM 取图仅限 model-response 内 blob/data 图，避免误选首页示例大图。",
  "nodes": [
    {
      "type": "navigate",
      "label": "导航",
      "params": {
        "url": "https://gemini.google.com/",
        "adsApiUrl": "http://127.0.0.1:50325",
        "waitUntil": "domcontentloaded",
        "useAdsPower": true,
        "adsProfileId": "{{browserInstanceId}}",
        "adsProxyServer": "",
        "adsManualCdpUrl": "{{browserWsUrl}}",
        "postClickEnabled": true,
        "postClickElements": [
          { "text": "Create image" },
          { "text": "制作图片" }
        ]
      },
      "waitAfter": {
        "action": "appeared",
        "enabled": true,
        "timeout": 60000,
        "selector": "rich-textarea .ql-editor[contenteditable=\"true\"], div.ql-editor[contenteditable=\"true\"]"
      }
    },
    {
      "type": "click",
      "label": "点击",
      "disabled": true,
      "params": {
        "text": "",
        "selector": "",
        "elements": [
          { "text": "Create image" },
          { "text": "制作图片" },
          { "selector": "text=Create image", "useSelector": true },
          { "selector": "text=制作图片", "useSelector": true }
        ]
      },
      "waitAfter": {
        "action": "appeared",
        "enabled": true,
        "timeout": 20000,
        "selector": "[aria-label*=\"Open upload file menu\" i], .upload-card-button"
      },
      "continueOnError": true
    },
    {
      "type": "paste_image_clipboard",
      "label": "上传参考图",
      "params": {
        "mode": "upload",
        "imageUrl": "{{sourceImageUrl}}",
        "imageUrls": "{{sourceImageUrls}}",
        "outputVar": "pastedImageUrls",
        "pasteHotkey": "ControlOrMeta+V",
        "targetSelector": "rich-textarea .ql-editor[contenteditable=\"true\"], div.ql-editor[contenteditable=\"true\"]",
        "uploadFallback": true,
        "waitAfterPaste": 1500,
        "waitAfterUpload": 2500,
        "verifyAttachment": true,
        "ensurePageFocused": true,
        "fileInputSelector": "",
        "fallbackOnNoEffect": true,
        "openUploaderSelector": "[aria-label*=\"Open upload file menu\" i], .upload-card-button",
        "attachIndicatorSelector": ".attachment-preview-wrapper, .file-preview-container, .file-preview-chip, img[aria-label=\"Image preview\"], [aria-label*=\"Remove file\" i]"
      }
    },
    {
      "type": "text_input",
      "label": "文本输入",
      "params": {
        "value": "{{noteUrl}}",
        "selector": "rich-textarea .ql-editor[contenteditable=\"true\"], div.ql-editor[contenteditable=\"true\"]",
        "inputMode": "type",
        "delay": 15,
        "autoEnter": false
      }
    },
    {
      "type": "click",
      "label": "点击",
      "params": {
        "text": "",
        "selector": "button[aria-label=\"Send message\"], button[aria-label*=\"发送\"], button[aria-label=\"Submit\"], button[aria-label*=\"Submit\" i], .send-button-container button"
      },
      "waitAfter": {
        "enabled": false
      }
    },
    {
      "type": "extract_image_download",
      "label": "⬇️ 下载事件提取",
      "params": {
        "ossPath": "gemini-images/{{timestamp}}.png",
        "outputVar": "imageUrl",
        "maxRetries": 5,
        "buttonIndex": -1,
        "uploadToOSS": true,
        "buttonTimeout": 60000,
        "waitAfterClick": 500,
        "downloadTimeout": 35000,
        "allowDomFallback": true,
        "preferDomExtraction": true,
        "fallbackImageSelector": "model-response img[src^=\"blob:\"], model-response img[src^=\"data:image\"]",
        "waitImageReady": true,
        "waitImageReadyTimeout": 240000,
        "waitImageReadyText": "正在加载",
        "waitImageReadySelector": "",
        "waitImageReadyAction": "appeared_then_disappeared",
        "waitImageReadyAppearTimeout": 30000,
        "menuItemSelector": "[role=\"menuitem\"]:has-text(\"Download\"), [role=\"menuitem\"]:has-text(\"下载\"), button:has-text(\"Download\"), button:has-text(\"下载\")",
        "minFileSizeBytes": 524288,
        "menuTriggerSelector": "button[aria-label*=\"More options\"], button[aria-label*=\"更多\"]",
        "failFastTextIncludes": "[\"没办法\",\"无法\"]",
        "allowClipboardFallback": true,
        "downloadButtonSelector": "[aria-label=\"Download image\"], [aria-label*=\"Download\"], [aria-label*=\"下载\"], button:has-text(\"Download\"), button:has-text(\"下载\")",
        "serializeClipboardAccess": true
      },
      "waitAfter": {
        "enabled": true
      },
      "continueOnError": false
    }
  ],
  "vars": [
    "browserInstanceId",
    "browserWsUrl",
    "noteUrl",
    "sourceImageUrl",
    "sourceImageUrls"
  ]
}
