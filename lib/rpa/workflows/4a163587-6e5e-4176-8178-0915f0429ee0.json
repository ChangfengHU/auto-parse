{
  "id": "4a163587-6e5e-4176-8178-0915f0429ee0",
  "name": "gemini流程管理-ads-下载提取版",
  "description": "基于非Ads基线流程，仅首节点切换Ads并支持浏览器实例参数\n\n支持可选参考图：sourceImageUrl（单张）/ sourceImageUrls（多张，JSON 数组或逗号分隔）。",
  "nodes": [
    {
      "type": "navigate",
      "label": "导航",
      "params": {
        "url": "https://gemini.google.com/",
        "adsApiUrl": "http://127.0.0.1:50325",
        "waitUntil": "domcontentloaded",
        "useAdsPower": true,
        "adsProfileId": "{{browserInstanceId}}",
        "adsProxyServer": "",
        "adsManualCdpUrl": "{{browserWsUrl}}",
        "postClickEnabled": false,
        "postClickElements": [
          {
            "text": "Create image",
            "selector": "",
            "useSelector": false
          },
          {
            "text": "制作图片",
            "selector": "",
            "useSelector": false
          }
        ]
      },
      "waitAfter": {
        "action": "appeared",
        "enabled": true,
        "timeout": 30000,
        "selector": "rich-textarea .ql-editor[contenteditable=\"true\"], div.ql-editor[contenteditable=\"true\"]"
      }
    },
    {
      "type": "click",
      "label": "点击",
      "params": {
        "text": "制作图片",
        "elements": [
          {
            "text": "Create image",
            "selector": "",
            "useSelector": false
          },
          {
            "text": "制作图片",
            "selector": "",
            "useSelector": false
          }
        ],
        "selector": "",
        "useSelector": true
      },
      "disabled": false,
      "waitAfter": {
        "action": "appeared",
        "enabled": false,
        "timeout": 20000,
        "selector": "[aria-label*=\"Open upload file menu\" i], .upload-card-button"
      },
      "continueOnError": true
    },
    {
      "type": "paste_image_clipboard",
      "label": "上传参考图",
      "params": {
        "mode": "upload",
        "imageUrl": "{{sourceImageUrl}}",
        "imageUrls": "{{sourceImageUrls}}",
        "outputVar": "pastedImageUrls",
        "pasteHotkey": "ControlOrMeta+V",
        "targetSelector": "rich-textarea .ql-editor[contenteditable=\"true\"], div.ql-editor[contenteditable=\"true\"]",
        "uploadFallback": true,
        "waitAfterPaste": 500,
        "waitAfterUpload": 500,
        "verifyAttachment": true,
        "ensurePageFocused": true,
        "fileInputSelector": "",
        "fallbackOnNoEffect": true,
        "openUploaderSelector": "[aria-label*=\"Open upload file menu\" i], .upload-card-button",
        "attachIndicatorSelector": ".attachment-preview-wrapper, .file-preview-container, .file-preview-chip, img[aria-label=\"Image preview\"], [aria-label*=\"Remove file\" i]"
      },
      "waitAfter": {
        "enabled": false,
        "timeout": 1000
      }
    },
    {
      "type": "text_input",
      "label": "文本输入",
      "params": {
        "delay": 15,
        "value": "{{noteUrl}}",
        "selector": "rich-textarea .ql-editor[contenteditable=\"true\"], div.ql-editor[contenteditable=\"true\"]",
        "autoEnter": true,
        "inputMode": "fill",
        "autoEnterPollUntilStop": true
      },
      "waitAfter": {
        "enabled": true,
        "timeout": 1500
      },
      "continueOnError": true
    },
    {
      "type": "extract_image_download",
      "label": "⬇️ 下载事件提取",
      "params": {
        "ossPath": "gemini-images/{{timestamp}}.png",
        "outputVar": "imageUrl",
        "maxRetries": 5,
        "buttonIndex": -1,
        "uploadToOSS": true,
        "buttonTimeout": 60000,
        "failFastAction": "fail_workflow",
        "storageBackend": "local_api",
        "waitAfterClick": 500,
        "waitImageReady": true,
        "downloadTimeout": 35000,
        "allowDomFallback": true,
        "menuItemSelector": "#model-response-message-contentr_b20191f329b36f8b > p > div > response-element > generated-image > single-image > div > div > div > download-generated-image-button > button > span.mdc-button__label > div > mat-icon",
        "minFileSizeBytes": 524288,
        "waitImageReadyText": "正在加载",
        "localFilesUploadUrl": "http://127.0.0.1:1002/v1beta/files:upload",
        "menuTriggerSelector": "button[aria-label*=\"More options\"], button[aria-label*=\"更多\"]",
        "failFastTextIncludes": [
          "没办法",
          "无法",
          "but",
          "error",
          "cannot",
          "can't",
          "Sorry",
          "wrong",
          "again",
          "hard",
          "Sorry"
        ],
        "allowClipboardFallback": true,
        "downloadButtonSelector": "[aria-label=\"Download image\"], [aria-label*=\"Download\"], [aria-label*=\"下载\"], button:has-text(\"Download\"), button:has-text(\"下载\")",
        "serializeClipboardAccess": true
      },
      "waitAfter": {
        "enabled": false,
        "timeout": 5000
      },
      "continueOnError": false
    },
    {
      "type": "click",
      "label": "点击",
      "params": {
        "text": "Submit",
        "selector": "#app-root > main > side-navigation-v2 > bard-sidenav-container > bard-sidenav-content > div.content-wrapper > div > div > chat-window > div > input-container > fieldset > input-area-v2 > div > div > div.trailing-actions-wrapper.ng-tns-c1819427631-6 > div.input-buttons-wrapper-bottom.ng-tns-c1819427631-6 > div.mat-mdc-tooltip-trigger.send-button-container.ng-tns-c1819427631-6.inner.ng-star-inserted.visible > button > mat-icon, button[aria-label=\"Submit\"], button[aria-label*=\"Submit\" i]",
        "useSelector": false
      },
      "disabled": true,
      "waitAfter": {
        "enabled": false,
        "timeout": 60000,
        "selector": "#model-response-message-contentr_b005ae4b34e346f5 > p > div > response-element > generated-image > single-image > div > div > div > download-generated-image-button > button > span.mdc-button__label > div",
        "delaySeconds": 3
      }
    }
  ],
  "vars": [
    "browserInstanceId",
    "browserWsUrl",
    "noteUrl",
    "sourceImageUrl",
    "sourceImageUrls"
  ]
}