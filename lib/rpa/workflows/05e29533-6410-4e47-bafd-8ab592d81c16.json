{
  "id": "05e29533-6410-4e47-bafd-8ab592d81c16",
  "name": "gemini流程管理-下载提取版",
  "description": "Restored non-ads baseline from current ads workflow",
  "nodes": [
    {
      "type": "navigate",
      "label": "导航",
      "params": {
        "url": "https://gemini.google.com/",
        "adsApiUrl": "http://127.0.0.1:50325",
        "waitUntil": "domcontentloaded",
        "useAdsPower": false,
        "adsProfileId": "",
        "adsProxyServer": "",
        "adsManualCdpUrl": ""
      },
      "waitAfter": {
        "action": "appeared",
        "enabled": true,
        "timeout": 60000,
        "selector": "rich-textarea .ql-editor[contenteditable=\"true\"], div.ql-editor[contenteditable=\"true\"]"
      }
    },
    {
      "type": "click",
      "label": "点击",
      "params": {
        "text": "Create image",
        "selector": ""
      },
      "waitAfter": {
        "enabled": false,
        "timeout": 100000,
        "selector": "img[src^=\"blob:\"], img[src^=\"data:image\"], button[aria-label=\"Copy image\"]",
        "delaySeconds": 3
      },
      "continueOnError": true
    },
    {
      "type": "text_input",
      "label": "文本输入",
      "params": {
        "value": "{{noteUrl}}",
        "selector": "rich-textarea .ql-editor[contenteditable=\"true\"], div.ql-editor[contenteditable=\"true\"]"
      }
    },
    {
      "type": "click",
      "label": "点击",
      "params": {
        "text": "",
        "selector": "button[aria-label=\"Send message\"], button[aria-label*=\"发送\"], .send-button-container button"
      },
      "waitAfter": {
        "enabled": true,
        "timeout": 180000,
        "selector": "[aria-label=\"Copy image\"], button[aria-label*=\"复制图片\"], button[aria-label*=\"Copy image\"], button:has-text(\"复制\"), img[src^=\"blob:\"], img[src^=\"data:image\"]",
        "delaySeconds": 3
      }
    },
    {
      "type": "extract_image_download",
      "label": "⬇️ 下载事件提取",
      "params": {
        "ossPath": "gemini-images/{{timestamp}}.png",
        "outputVar": "imageUrl",
        "maxRetries": 3,
        "buttonIndex": -1,
        "uploadToOSS": true,
        "buttonTimeout": 60000,
        "waitAfterClick": 500,
        "downloadTimeout": 25000,
        "allowDomFallback": false,
        "minFileSizeBytes": 524288,
        "downloadButtonSelector": "[aria-label=\"Download image\"], [aria-label*=\"Download\"], [aria-label*=\"下载\"], button:has-text(\"Download\"), button:has-text(\"下载\")"
      },
      "waitAfter": {
        "enabled": true
      },
      "continueOnError": false
    }
  ]
}