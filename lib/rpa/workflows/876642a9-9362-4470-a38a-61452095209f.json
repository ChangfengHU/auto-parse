{
  "id": "876642a9-9362-4470-a38a-61452095209f",
  "name": "抖音视频发布 (副本)",
  "description": "上传视频到抖音创作者平台并发布",
  "nodes": [
    {
      "type": "navigate",
      "label": "打开创作者首页",
      "params": {
        "url": "https://creator.douyin.com",
        "waitUntil": "domcontentloaded",
        "useAdsPower": false,
        "adsProfileId": "k1b908rw"
      }
    },
    {
      "url": "https://images.vyibc.com/api-integration.html",
      "type": "qrcode",
      "label": "检测登录状态（未登录则扫码）",
      "params": {
        "timeout": 300000,
        "excludeUrls": [
          "/login",
          "qrcode",
          "passport"
        ],
        "cookieDomain": "douyin.com",
        "refreshInterval": 110000,
        "successUrlContains": "creator-micro"
      }
    },
    {
      "type": "navigate",
      "label": "导航到视频上传页",
      "params": {
        "url": "https://creator.douyin.com/creator-micro/content/upload",
        "waitUntil": "domcontentloaded"
      }
    },
    {
      "type": "file_upload",
      "label": "上传视频文件",
      "params": {
        "url": "{{videoUrl}}",
        "selector": "input[accept*=\"video/mp4\"], input[accept*=\"video\"], input[type=\"file\"]"
      }
    },
    {
      "type": "wait_condition",
      "label": "等待跳转到填写信息页",
      "params": {
        "timeout": 120000,
        "urlContains": "content/post",
        "timeoutAction": "continue"
      }
    },
    {
      "type": "text_input",
      "label": "填写标题",
      "params": {
        "value": "{{title}}",
        "selector": ".zone-container"
      }
    },
    {
      "type": "scroll",
      "label": "滚动到页面底部",
      "params": {
        "y": 800,
        "behavior": "smooth"
      }
    },
    {
      "type": "wait_condition",
      "label": "等待内容检测",
      "params": {
        "timeout": 180000,
        "condition": "value > 94",
        "textMatch": "检测中\\s*(\\d+)\\s*%",
        "failKeywords": [
          "违规",
          "无法发布",
          "检测失败",
          "审核不通过",
          "发布失败",
          "不符合",
          "风险",
          "限流"
        ],
        "pollInterval": 2000,
        "timeoutAction": "continue",
        "successKeywords": [
          "作品未见异常",
          "检测通过",
          "内容正常",
          "未见风险"
        ],
        "verifyButtonText": "发布"
      }
    },
    {
      "type": "click",
      "label": "点击发布",
      "params": {
        "text": "发布"
      }
    },
    {
      "type": "wait_condition",
      "label": "等待发布完成",
      "params": {
        "timeout": 60000,
        "urlContains": "/content/manage",
        "timeoutAction": "fail"
      }
    },
    {
      "type": "screenshot",
      "label": "发布成功截图",
      "params": {}
    }
  ]
}