{
  "id": "47a6aa3a-f57f-487d-8e59-0212ffd5ce1e",
  "name": "gemini流程管理",
  "description": "Restored non-ads baseline from current ads workflow",
  "nodes": [
    {
      "type": "navigate",
      "label": "导航",
      "params": {
        "url": "https://gemini.google.com/",
        "adsApiUrl": "http://127.0.0.1:50325",
        "waitUntil": "domcontentloaded",
        "useAdsPower": false,
        "adsProfileId": "",
        "adsProxyServer": "",
        "adsManualCdpUrl": ""
      },
      "waitAfter": {
        "action": "appeared",
        "enabled": true,
        "timeout": 60000,
        "selector": "rich-textarea .ql-editor[contenteditable=\"true\"], div.ql-editor[contenteditable=\"true\"]"
      }
    },
    {
      "type": "click",
      "label": "点击",
      "params": {
        "text": "Create image",
        "selector": ""
      },
      "waitAfter": {
        "enabled": false,
        "timeout": 100000,
        "selector": "img[src^=\"blob:\"], img[src^=\"data:image\"], button[aria-label=\"Copy image\"]",
        "delaySeconds": 3
      },
      "continueOnError": true
    },
    {
      "type": "text_input",
      "label": "文本输入",
      "params": {
        "value": "{{noteUrl}}",
        "selector": "rich-textarea .ql-editor[contenteditable=\"true\"], div.ql-editor[contenteditable=\"true\"]"
      }
    },
    {
      "type": "click",
      "label": "点击",
      "params": {
        "text": "",
        "selector": "button[aria-label=\"Send message\"], button[aria-label*=\"发送\"], .send-button-container button"
      },
      "waitAfter": {
        "enabled": true,
        "timeout": 180000,
        "selector": "[aria-label=\"Copy image\"], button[aria-label*=\"复制图片\"], button[aria-label*=\"Copy image\"], button:has-text(\"复制\"), img[src^=\"blob:\"], img[src^=\"data:image\"]",
        "delaySeconds": 3
      }
    },
    {
      "type": "extract_image_clipboard",
      "label": "📋 剪贴板高清提取",
      "params": {
        "ossPath": "gemini-images/{{timestamp}}.png",
        "outputVar": "imageUrl",
        "uploadToOSS": true,
        "waitAfterCopy": 1500,
        "copyButtonSelector": "[aria-label=\"Copy image\"], button[aria-label*=\"复制图片\"], button[aria-label*=\"Copy image\"], button:has-text(\"复制\")"
      },
      "waitAfter": {
        "enabled": true
      },
      "continueOnError": false
    }
  ]
}